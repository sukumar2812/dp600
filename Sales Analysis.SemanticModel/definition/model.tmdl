model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-IN
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Sales","Territories","Product","Customer","Calendar","Refresh Time","Product demo","Config"]

annotation PBI_ProTooling = ["DaxQueryView_Desktop","TMDLView_Desktop"]

annotation __TEdtr = 1

ref table Sales
ref table Territories
ref table Product
ref table Customer
ref table Calendar
ref table hello1
ref table 'Refresh Time'
ref table 'Product demo'
ref table Config
ref table Parameter

ref role RLS

ref cultureInfo en-US

