model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-IN
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["DirectLake - LH01","Territories"]

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["RemoteModeling","DirectLakeOnOneLakeCreatedInDesktop","TMDLView_Desktop","DaxQueryView_Desktop","DevMode"]

ref table Customer
ref table Sales
ref table Territories

